# ─────────────────────────────────────────────────────────────
# MercadinhoSys — Backend (.env.example)
# Copie para `.env` e preencha. NUNCA commite o `.env` real.
# ─────────────────────────────────────────────────────────────

# Banco de dados (Postgres em produção). Aceita postgres:// ou postgresql://
DATABASE_URL=postgresql://user:password@localhost:5432/mercadinho

# Segurança (gere valores fortes e únicos em produção)
JWT_SECRET_KEY=troque-por-um-segredo-forte
FLASK_ENV=development            # development | testing | production | simulation

# ─── Observabilidade (Sentry) — opcional, NO-OP se vazio ───
# Cole o DSN do projeto Sentry para ativar o monitoramento de erros.
SENTRY_DSN=
# 0.0–1.0 (fração de transações amostradas). Default 0.1 (10%) — suba só se precisar.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Sobrescreve o nome do ambiente exibido no Sentry (default = FLASK_ENV).
SENTRY_ENVIRONMENT=
# Versão/release (ex.: hash do commit). No Render, RENDER_GIT_COMMIT já é usado.
SENTRY_RELEASE=

# ─── Cache (opcional) ───
# Se definido, usa Redis; senão, cache em memória (SimpleCache).
REDIS_URL=

# ─── Sincronização offline (mantido desligado por padrão) ───
SYNC_ENABLED=false
