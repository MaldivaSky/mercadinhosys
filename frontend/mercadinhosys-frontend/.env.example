# ─────────────────────────────────────────────────────────────
# MercadinhoSys — Frontend (.env.example)
# Variáveis Vite precisam do prefixo VITE_. Copie para `.env`.
# ─────────────────────────────────────────────────────────────

# URL base da API (em produção é fixada no vercel.json)
VITE_API_URL=http://localhost:5000/api

# ─── Observabilidade (Sentry) — opcional, NO-OP se vazio ───
# Cole o DSN do projeto Sentry (frontend) para ativar o monitoramento.
VITE_SENTRY_DSN=
# 0.0–1.0 — fração de transações amostradas. Default 0.1 (10%).
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Versão/release (ex.: hash do commit) — opcional.
VITE_SENTRY_RELEASE=
