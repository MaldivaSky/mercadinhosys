# MercadinhoSys - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores

# ==================== FLASK ====================
FLASK_ENV=production
FLASK_APP=run.py

# ==================== DATABASE ====================
DB_PASSWORD=mercadinho_secure_pass_2024_CHANGE_ME
DATABASE_URL=postgresql://mercadinho_user:mercadinho_secure_pass_2024_CHANGE_ME@postgres:5432/mercadinhosys

# ==================== SECURITY ====================
# IMPORTANTE: Gere chaves seguras em produção! (config.py RECUSA subir em
# FLASK_ENV=production sem SECRET_KEY e JWT_SECRET_KEY definidos.)
# Exemplo: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-CHANGE-IN-PRODUCTION
JWT_SECRET_KEY=your-jwt-secret-key-CHANGE-IN-PRODUCTION

# ==================== SYNC LOCAL → AIVEN (nuvem) ====================
# URL do Postgres do Aiven (destino do sync). Sem isso, o sync não roda.
AIVEN_DATABASE_URL=postgres://avnadmin:SENHA@host-aiven.aivencloud.com:PORTA/defaultdb?sslmode=require
# Ligado por padrão no serviço dedicado "sync" do docker-compose.
SYNC_AUTO_PUSH=true
SYNC_PUSH_INTERVAL_SEC=300
# Observabilidade: GET /api/sync/health → {sync_saudavel, sync_idade_minutos, heartbeat}

# ==================== CORS ====================
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:80

# ==================== REDIS ====================
REDIS_PASSWORD=redis_secure_pass_CHANGE_ME

# ==================== EMAIL (Gmail) ====================
# Para gerar senha de app: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app-16-caracteres
MAIL_DEFAULT_SENDER=seu-email@gmail.com

# ==================== BACKUP ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Diariamente às 2h da manhã

# ==================== MONITORING (Opcional) ====================
SENTRY_DSN=
LOG_LEVEL=INFO
